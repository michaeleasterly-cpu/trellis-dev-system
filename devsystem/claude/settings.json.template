{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "$comment": "Project-scoped Claude Code settings for {{ project_name }}. Generated by the Trellis bootstrap. The version-controlled architecture surface (rules/skills/agents/hooks under .claude/, settings.json itself) is the consumer-facing contract; per-machine state lives in .claude/settings.local.json (gitignored). Hooks wire the portable .claude/hooks/*.sh enforcement scripts. Authoritative external: https://code.claude.com/docs/en/hooks-guide.",
  "worktree": {
    "baseRef": "fresh",
    "bgIsolation": "worktree"
  },
  "$comment_permissions": "deny list: secret files + destructive ops. Anthropic-canonical second layer (hooks bypassable, deny not).",
  "permissions": {
    "defaultMode": "default",
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Read(./secrets/**)",
      "Edit(./secrets/**)",
      "Write(./secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.netrc)",
      "Read(~/.config/gh/**)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)",
      "Bash(dd if=*)",
      "Bash(chmod -R 777 *)",
      "Bash(chown -R *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-git-checkout.sh"},
          {"type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-pytest-subset-when-critical.sh"}
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {"type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"}
        ]
      }
    ]
  }
}
